{
  "name": "rarog",
  "version": "1.0.0",
  "description": "Rarog CSS Framework — современный гибридный CSS-фреймворк на базе дизайн-токенов, утилит и компонентов.",
  "author": "TheSkiF4er <dev@cajeer.ru>",
  "license": "Apache-2.0",
  "scripts": {
    "build": "npm run build:all",
    "build:css": "node tools/build.mjs",
    "build:core": "node tools/build.mjs core",
    "build:utilities": "node tools/build.mjs utilities",
    "build:components": "node tools/build.mjs components",
    "build:themes": "node tools/build.mjs themes",
    "build:js": "node tools/build-js.mjs",
    "build:adapters": "node tools/build-adapters.mjs",
    "build:all": "npm run build:css && npm run build:js && npm run build:adapters",
    "docs": "node tools/docs-dev.mjs",
    "docs:dev": "node tools/docs-dev.mjs",
    "docs:build": "node tools/build-docs-site.mjs",
    "docs:preview": "node tools/docs-dev.mjs --dir .gitbook/dist",
    "storybook": "storybook dev -p 6006 --host 127.0.0.1",
    "storybook:build": "storybook build",
    "storybook:smoke": "node tests/storybook/storybook-smoke.mjs",
    "test": "npm run test:unit && npm run test:adapters && npm run test:e2e",
    "test:unit": "vitest run tests/js",
    "test:unit:watch": "vitest",
    "test:adapters": "npm run build:js && npm run build:adapters && vitest run tests/adapters",
    "test:ci": "npm run test:unit && npm run test:adapters && npm run test:contracts && npm run test:smoke",
    "test:contracts": "vitest run tests/js/component-contracts.test.js tests/js/contract-sweep.test.js tests/js/dispose-contract.test.js tests/js/event-contract.test.js tests/js/event-contract-core.test.js tests/js/event-contract-overlay-components.test.js",
    "test:e2e": "playwright test",
    "visual:serve": "node tools/visual-dev.mjs --port 4175",
    "test:visual": "playwright test -c playwright.visual.config.ts",
    "release:check": "node tools/check-release.mjs",
    "release:verify": "npm run release:check && npm run docs:check",
    "verify:artifacts": "node tools/check-package-artifacts.mjs",
    "pack:packages": "node tools/pack-packages.mjs",
    "docs:check": "npm run docs:lint && npm run docs:build && node tools/check-docs-output.mjs",
    "docs:lint": "node tools/check-docs.mjs",
    "test:release": "npm run test:unit && npm run test:adapters && npm run test:contracts && npm run test:smoke",
    "test:smoke": "node tests/cli-temp-project-smoke.mjs",
    "migrate:bootstrap": "node packages/cli/bin/rarog.js migrate bootstrap",
    "migrate:tailwind": "node packages/cli/bin/rarog.js migrate tailwind",
    "inspect:classes": "node packages/cli/bin/rarog.js inspect classes",
    "dev": "npm run docs",
    "build:app": "npm run build:all",
    "rarog:build": "npm run build:all",
    "playground": "npm run docs",
    "test:starters": "node tests/cli-temp-project-smoke.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheSkiF4er/rarog.git"
  },
  "bugs": {
    "url": "https://github.com/TheSkiF4er/rarog/issues"
  },
  "homepage": "https://cajeer.ru/rarog",
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@storybook/addon-a11y": "^8.4.7",
    "@storybook/addon-docs": "^8.4.7",
    "@storybook/html-vite": "^8.4.7",
    "autoprefixer": "^10.4.0",
    "cssnano": "^6.0.0",
    "esbuild": "^0.24.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.0",
    "postcss-cli": "^11.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "storybook": "^8.4.7",
    "vite": "^5.4.10",
    "vitest": "^1.0.0",
    "vue": "^3.5.12",
    "vscode-languageserver": "^9.0.0"
  },
  "bin": {
    "rarog": "packages/cli/bin/rarog.js"
  },
  "style": "./packages/core/dist/rarog-core.min.css",
  "exports": {
    ".": "./packages/core/dist/rarog-core.min.css",
    "./core": "./packages/core/dist/rarog-core.min.css",
    "./utilities": "./packages/utilities/dist/rarog-utilities.min.css",
    "./components": "./packages/components/dist/rarog-components.min.css",
    "./themes/default": "./packages/themes/dist/rarog-theme-default.min.css",
    "./themes/dark": "./packages/themes/dist/rarog-theme-dark.min.css",
    "./themes/contrast": "./packages/themes/dist/rarog-theme-contrast.min.css",
    "./cli": "./packages/cli/bin/rarog.js",
    "./themes/creative": "./packages/themes/dist/rarog-theme-creative.min.css",
    "./themes/enterprise": "./packages/themes/dist/rarog-theme-enterprise.min.css",
    "./package.json": "./package.json",
    "./presets": "./packages/presets/registry.json"
  },
  "files": [
    "packages/cli/bin",
    "packages/cli/lib",
    "packages/core/dist",
    "packages/utilities/dist",
    "packages/components/dist",
    "packages/themes/dist",
    "packages/presets",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "packages/*"
  ],
  "publishConfig": {
    "access": "public"
  }
}
