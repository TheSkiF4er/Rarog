{
  "name": "rarog",
  "version": "3.5.0",
  "description": "Rarog CSS Framework — современный гибридный CSS-фреймворк на базе дизайн-токенов, утилит и компонентов.",
  "author": "TheSkiF4er <dev@cajeer.ru>",
  "license": "Apache-2.0",
  "main": "packages/core/dist/rarog-core.min.css",
  "scripts": {
    "build": "node tools/build.mjs",
    "build:core": "node tools/build.mjs core",
    "build:utilities": "node tools/build.mjs utilities",
    "build:components": "node tools/build.mjs components",
    "build:themes": "node tools/build.mjs themes",
    "docs": "node tools/docs-dev.mjs",
    "docs:dev": "vitepress dev docs-site",
    "docs:build": "vitepress build docs-site",
    "docs:preview": "vitepress preview docs-site",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "build:adapters": "node tools/build-adapters.mjs",
    "build:react": "node tools/build-adapters.mjs react",
    "build:vue": "node tools/build-adapters.mjs vue",
    "pack:react": "npm pack ./packages/react",
    "pack:vue": "npm pack ./packages/vue",
    "test:adapters:smoke": "npm run build:adapters && vitest run tests/adapters/**/*.test.js",
    "build:js": "node tools/build-js.mjs",
    "build:all": "npm run build && npm run build:js && npm run build:adapters",
    "pack:js": "npm pack ./packages/js",
    "pack:packages": "npm run pack:js && npm run pack:react && npm run pack:vue",
    "test:smoke": "node tests/rarog-build-regress.test.mjs && node tests/rarog-release-sync.test.mjs && npm run test:adapters:smoke",
    "release:verify": "node tools/check-release.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheSkiF4er/rarog.git"
  },
  "bugs": {
    "url": "https://github.com/TheSkiF4er/rarog/issues"
  },
  "homepage": "https://cajeer.ru/rarog",
  "devDependencies": {
    "postcss": "^8.4.0",
    "postcss-cli": "^11.0.0",
    "autoprefixer": "^10.4.0",
    "cssnano": "^6.0.0",
    "vitepress": "latest",
    "vitest": "^1.0.0",
    "vscode-languageserver": "^9.0.0",
    "@playwright/test": "^1.49.0",
    "esbuild": "^0.25.0",
    "jsdom": "^24.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vue": "^3.5.13"
  },
  "bin": {
    "rarog": "packages/cli/bin/rarog.js"
  },
  "workspaces": [
    "packages/*"
  ],
  "packageManager": "npm@10.9.2"
}
