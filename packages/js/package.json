{
  "name": "@rarog/js",
  "version": "3.5.0",
  "description": "vanilla js runtime for rarog interactive components",
  "author": "TheSkiF4er <dev@cajeer.ru>",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/rarog.cjs",
  "module": "dist/rarog.esm.js",
  "types": "dist/index.d.ts",
  "unpkg": "dist/rarog.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/rarog.esm.js",
      "require": "./dist/rarog.cjs",
      "default": "./dist/rarog.esm.js"
    },
    "./browser": {
      "default": "./dist/rarog.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node ../../tools/build-js.mjs",
    "prepack": "node ../../tools/build-js.mjs"
  },
  "publishConfig": {
    "access": "public"
  }
}
