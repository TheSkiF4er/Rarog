{
  "name": "@rarog/react",
  "version": "3.5.0",
  "description": "react bindings for rarog js core and component primitives",
  "author": "TheSkiF4er <dev@cajeer.ru>",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "src"
  ],
  "peerDependencies": {
    "@rarog/js": ">=3.5.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "source": "src/index.js",
  "scripts": {
    "build": "node ../../tools/build-adapters.mjs",
    "prepack": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  }
